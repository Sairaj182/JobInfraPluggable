# Server Configuration
SERVER_PORT=8080

# Database Configuration
POSTGRES_DB=jobinfra
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/jobinfra

# JWT Configuration
# Generate a 256-bit (32-byte) base64 string for the secret key
JWT_SECRET=4f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a
JWT_EXPIRATION_MS=86400000

# Docker specific overrides can be placed below if needed

# Webhook Configuration
JOBINFRA_WEBHOOK_SECRET=your_super_secret_webhook_key_here
JOBINFRA_WEBHOOK_TIMEOUT_MS=5000
