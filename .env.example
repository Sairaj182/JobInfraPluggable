# Server Configuration
SERVER_PORT=8080

# Database Configuration
POSTGRES_DB=your_db_name
POSTGRES_USER=your_user_name
POSTGRES_PASSWORD=your_pass
SPRING_DATASOURCE_URL=your_db_url

# JWT Configuration
# Generate a 256-bit (32-byte) base64 string for the secret key
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION_MS=86400000

# Docker specific overrides can be placed below if needed

# Webhook Configuration
JOBINFRA_WEBHOOK_SECRET=your_super_secret_webhook_key_here
JOBINFRA_WEBHOOK_TIMEOUT_MS=5000
